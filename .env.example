# ─── Discord ────────────────────────────────────────────────────────────────

# Bot token from https://discord.com/developers/applications. Treat as secret.
DISCORD_BOT_TOKEN=

# Numeric Discord user ID of the only person allowed to DM the bot.
# Right-click your profile → Copy User ID (requires Developer Mode in
# Discord's Advanced settings).
OPERATOR_DISCORD_ID=

# ─── Model provider ────────────────────────────────────────────────────────

# Anthropic API key. Inherited by the Loom subprocess; the Anthropic harness
# reads it. The orchestrator itself never touches the key.
ANTHROPIC_API_KEY=

# ─── Vault ─────────────────────────────────────────────────────────────────

# Absolute path to your Glass vault: the directory the agent reads and writes
# her notes, soul (`_glass/soul.md`), and journal in. The agent's read/write/
# edit/find/bash capabilities are restricted to this directory in the
# manifests via `${GLASS_VAULT_DIR}` substitution (Loom ≥0.1.5), so this is
# both her content substrate AND the security boundary on her filesystem
# access.
#
# Must be ABSOLUTE — Loom doesn't expand `~` in capability paths. Recommended
# layout: a directory inside a synced folder (Dropbox / iCloud Drive / git)
# so the agent's content survives across machines. Examples:
#   /Users/alice/Dropbox/glass-vault
#   /home/alice/.glass-vault
#
# Required: if you don't set this, `loom audit` and `loom prompt` will fail
# at manifest-parse time with a clear "Manifest references undefined env
# var" error. If you want a hardcoded default instead, edit the manifests
# to use `${GLASS_VAULT_DIR:-/your/default/path}` shell-style fallback.
GLASS_VAULT_DIR=

# ─── Orchestrator (optional overrides; defaults shown) ─────────────────────

# Path to the DM agent manifest.
# MANIFEST=./manifests/glass.toml

# Path to the cron agent manifest.
# CRON_MANIFEST=./manifests/cron.toml

# The `loom` binary to invoke per turn. `scripts/run.sh` prepends
# `node_modules/.bin` to PATH so the workspace-vendored copy resolves first;
# if you run `cargo run` directly, this needs to find a `loom` on PATH.
# LOOM_COMMAND=loom

# Where Glass-the-system writes operational state: invocation logs,
# the orchestrator socket, the cron schedule file, the dm-log. Distinct from
# the vault (which is Glass-the-agent's content).
# Defaults:
#   macOS:  ~/Library/Application Support/Glass
#   Linux:  $XDG_DATA_HOME/glass  (typically ~/.local/share/glass)
# GLASS_SYSTEM_DATA=

# Tracing filter for the Rust side. See tracing-subscriber EnvFilter syntax.
# `glass::loom=trace` includes every raw event line Loom emits — useful for
# diagnosing failed turns until you've inspected `$GLASS_SYSTEM_DATA/invocations/`.
# RUST_LOG=glass=info,serenity=warn
