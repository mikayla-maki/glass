# Discord bot
DISCORD_BOT_TOKEN=
# Numeric Discord user ID of the only person allowed to DM the bot.
# Right-click your Discord profile -> Copy User ID (you need Developer Mode on).
OWNER_DISCORD_ID=

# Anthropic API key. Read by Pi when it's invoked. Glass itself doesn't touch it.
ANTHROPIC_API_KEY=

# Optional
# WORKSPACE_PATH=./workspace
# PI_COMMAND=pi
# MODELS_CONFIG=./models.toml
# RUST_LOG=glass=info,serenity=warn
