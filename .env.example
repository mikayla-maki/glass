# ─── Discord ────────────────────────────────────────────────────────────────

# Bot token from https://discord.com/developers/applications. Treat as secret.
DISCORD_BOT_TOKEN=

# Numeric Discord user ID of the only person allowed to DM the bot.
# Right-click your profile → Copy User ID (requires Developer Mode in
# Discord's Advanced settings).
OWNER_DISCORD_ID=

# ─── Model provider ────────────────────────────────────────────────────────

# Anthropic API key. Inherited by the Loom subprocess; the Anthropic harness
# reads it. The orchestrator itself never touches the key.
ANTHROPIC_API_KEY=

# ─── Orchestrator (optional overrides; defaults shown) ─────────────────────

# Path to the agent manifest, resolved relative to the repo root.
# MANIFEST=./manifests/glass.toml

# The `loom` binary to invoke per DM turn. `scripts/run.sh` prepends
# `node_modules/.bin` to PATH so the workspace-vendored copy resolves first;
# if you run `cargo run` directly, this needs to find a `loom` on PATH.
# LOOM_COMMAND=loom

# Where Glass-the-system writes operational state — invocation logs (v0.4),
# the orchestrator socket (v0.4), and anything else the bot needs to persist
# that isn't part of Glass-the-agent's content (which lives in the vault).
# Defaults:
#   macOS:  ~/Library/Application Support/Glass
#   Linux:  $XDG_DATA_HOME/glass  (typically ~/.local/share/glass)
# GLASS_SYSTEM_DATA=

# Tracing filter for the Rust side. See tracing-subscriber EnvFilter syntax.
# RUST_LOG=glass=info,serenity=warn
